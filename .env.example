# OpenAI API Key for AI summarization (optional)
OPENAI_API_KEY="sk-your-api-key-here"

# Instagram Session ID for GraphQL follower extraction (REQUIRED for follower list)
# How to get it:
#   1. Open Instagram in Chrome
#   2. Press F12 → Application tab → Cookies → instagram.com
#   3. Copy the value of "sessionid"
#   4. Paste it below
IG_SESSION_ID=""

# Max concurrent requests (default: 3)
MAX_CONCURRENT=3

# --- Instagram Scraper Configuration ---

# The target Instagram profile username to start scraping from
IG_ROOT_TARGET="instagram_username"

# Maximum number of followers to scrape from the root target
IG_MAX_FOLLOWERS=10

# Maximum number of posts to scrape per user (root and followers)
IG_MAX_POSTS=5

# Maximum number of comments to scrape per post
IG_MAX_COMMENTS=5

# --- Authentication ---
# Required for authenticated scraping. Get these from your browser cookies.
IG_SESSION_ID="your_session_id_here"
IG_CSRFTOKEN="your_csrf_token_here"
IG_DS_USER_ID="your_user_id_here"

# --- AI Analysis (Optional) ---
# API Key for profile summarization (OpenAI)
OPENAI_API_KEY="your_openai_api_key_here"

# API Key for psychology analysis (Groq) - Alternative to OpenAI
GROQ_API_KEY="your_groq_api_key_here"

# --- Performance ---
# Number of concurrent requests/processes
MAX_CONCURRENT=3
